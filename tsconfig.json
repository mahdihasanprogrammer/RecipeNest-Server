{
  "compilerOptions": {
    "target": "ES2022", 
    "module": "CommonJS",                        // 👈 এক্সপ্রেসের জন্য সবচেয়ে সেফ ও পপুলার
    "rootDir": "./",                             // 👈 প্রজেক্ট রুট থেকে শুরু হবে
    "outDir": "./dist",                          // 👈 বিল্ড ফাইলগুলো dist ফোল্ডারে যাবে
    "strict": true,                              
    "skipLibCheck": true,
    "esModuleInterop": true,                     // 👈 CommonJS এবং ESM মিক্সড ইম্পোর্ট হ্যান্ডেল করবে
    "forceConsistentCasingInFileNames": true
  },
  "include": ["index.ts"],                       // 👈 শুধুমাত্র আপনার রুট index.ts কম্পাইল করবে
  "exclude": ["node_modules", "dist"]            // 👈 dist ফোল্ডার বাদ দেওয়া অত্যন্ত জরুরি
}